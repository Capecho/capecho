{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "capecho-web",
  "main": ".open-next/worker.js",
  // Must be >= 2024-09-23 for @opennextjs/cloudflare; kept at/under the pinned
  // local workerd's date so `pnpm run preview` doesn't warn about a future date.
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
